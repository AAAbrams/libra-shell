{
    "name": "libra/shell",
    "description": "Composable Inertia microframework with Slim, Twig and React SSR",
    "type": "library",
    "bin": [
        "bin/libra-shell-init"
    ],
    "autoload": {
        "psr-4": {
            "Libra\\Shell\\": "src/"
        }
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/AAAbrams/inertia-psr15.git"
        }
    ],
    "require": {
        "laminas/laminas-diactoros": "2.0.0",
        "libra/inertia-psr15": "^1.0",
        "slim/slim": "^3.12",
        "slim/twig-view": "^2.5",
        "vlucas/phpdotenv": "^5.6"
    },
    "config": {
        "sort-packages": true,
        "platform": {
            "php": "7.2.34"
        },
        "audit": {
            "ignore": [
                "PKSA-y2cr-5h3j-g3ys",
                "PKSA-yg4s-vh6g-jnyh",
                "PKSA-wdyb-c3m7-9v88"
            ]
        }
    }
}
