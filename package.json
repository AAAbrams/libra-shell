{
    "name": "libra-shell-frontend",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "build:all": "npm run build && npm run build:ssr",
        "watch": "vite build --watch",
        "build:ssr": "vite build --ssr resources/js/app/entries/server.tsx",
        "preview": "vite preview",
        "serve:ssr": "node ../../assets/libra.shell/ssr/ssr.js",
        "dev:ssr": "npm run build:ssr && npm run serve:ssr",
        "typecheck": "tsc -b"
    },
    "dependencies": {
        "@inertiajs/react": "^3.0.3",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lucide-react": "^1.8.0",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "tailwind-merge": "^3.5.0"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.2.2",
        "@types/node": "^25.6.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^4.7.0",
        "shadcn": "^4.2.0",
        "tailwindcss": "^4.2.2",
        "tw-animate-css": "^1.4.0",
        "typescript": "^5.9.3",
        "vite": "^6.4.2"
    }
}
